diff --git a/extensions/whatsapp/src/auto-reply/monitor/routing-policy.test.ts b/extensions/whatsapp/src/auto-reply/monitor/routing-policy.test.ts
new file mode 100644
index 0000000000..ff4c829a70
--- /dev/null
+++ b/extensions/whatsapp/src/auto-reply/monitor/routing-policy.test.ts
@@ -0,0 +1,182 @@
+import { resolveAgentRoute } from "openclaw/plugin-sdk/routing";
+import { describe, expect, it } from "vitest";
+import type { OpenClawConfig } from "../../../../../src/config/config.js";
+import { applyWhatsAppRoutingPolicy } from "./routing-policy.js";
+
+function makeConfig(): OpenClawConfig {
+  return {
+    acp: { defaultAgent: "main" },
+    channels: {
+      whatsapp: {
+        allowFrom: ["*"],
+      },
+    },
+    agents: {
+      list: [
+        {
+          id: "main",
+          identity: { name: "Michael" },
+          groupChat: { mentionPatterns: ["Michael", "@Michael", "michael"] },
+        },
+        {
+          id: "bsc",
+          identity: { name: "Brian" },
+          groupChat: { mentionPatterns: ["Brian", "@Brian", "brian"] },
+        },
+        {
+          id: "zen",
+          identity: { name: "Zack" },
+          groupChat: { mentionPatterns: ["Zack", "@Zack", "zack"] },
+        },
+      ],
+    },
+  };
+}
+
+function buildRoute(
+  cfg: OpenClawConfig,
+  msg: { chatType: "direct" | "group"; accountId?: string; from: string },
+) {
+  return resolveAgentRoute({
+    cfg,
+    channel: "whatsapp",
+    accountId: msg.accountId,
+    peer: {
+      kind: msg.chatType === "group" ? "group" : "direct",
+      id: msg.from,
+    },
+  });
+}
+
+function buildMessage(
+  overrides: Partial<Parameters<typeof applyWhatsAppRoutingPolicy>[0]["msg"]> = {},
+) {
+  return {
+    id: "m1",
+    from: "+15550001111",
+    conversationId: "+15550001111",
+    chatId: "direct:+15550001111",
+    chatType: "direct" as const,
+    to: "+2000",
+    body: "Michael what is your name",
+    accountId: "default",
+    senderE164: "+15550001111",
+    senderName: "Tester",
+    selfE164: "+2000",
+    sendComposing: async () => {},
+    reply: async () => {},
+    sendMedia: async () => {},
+    ...overrides,
+  };
+}
+
+describe("applyWhatsAppRoutingPolicy", () => {
+  it("routes owner DMs to the explicitly named agent", () => {
+    const cfg = makeConfig();
+    const msg = buildMessage({
+      body: "Brian what is your name",
+      senderE164: "+628176917122",
+      from: "+628176917122",
+      conversationId: "+628176917122",
+      chatId: "direct:+628176917122",
+    });
+
+    const route = applyWhatsAppRoutingPolicy({
+      cfg,
+      msg,
+      route: buildRoute(cfg, msg),
+      peerId: msg.from,
+    });
+
+    expect(route?.agentId).toBe("bsc");
+  });
+
+  it("allows non-owner DMs only when Michael is mentioned", () => {
+    const cfg = makeConfig();
+    const michaelMsg = buildMessage({
+      body: "Michael status",
+      senderE164: "+15550001111",
+    });
+    const michaelRoute = applyWhatsAppRoutingPolicy({
+      cfg,
+      msg: michaelMsg,
+      route: buildRoute(cfg, michaelMsg),
+      peerId: michaelMsg.from,
+    });
+    expect(michaelRoute?.agentId).toBe("main");
+
+    const brianMsg = buildMessage({
+      body: "Brian status",
+      senderE164: "+15550001111",
+    });
+    const blockedRoute = applyWhatsAppRoutingPolicy({
+      cfg,
+      msg: brianMsg,
+      route: buildRoute(cfg, brianMsg),
+      peerId: brianMsg.from,
+    });
+    expect(blockedRoute).toBeNull();
+  });
+
+  it("blocks direct messages with no allowed named agent", () => {
+    const cfg = makeConfig();
+    const msg = buildMessage({
+      body: "what is your name",
+      senderE164: "+628176917122",
+      from: "+628176917122",
+      conversationId: "+628176917122",
+      chatId: "direct:+628176917122",
+    });
+
+    const route = applyWhatsAppRoutingPolicy({
+      cfg,
+      msg,
+      route: buildRoute(cfg, msg),
+      peerId: msg.from,
+    });
+
+    expect(route).toBeNull();
+  });
+
+  it("routes group messages only when Brian is mentioned", () => {
+    const cfg = makeConfig();
+    const msg = buildMessage({
+      from: "120363407581810735@g.us",
+      conversationId: "120363407581810735@g.us",
+      chatId: "120363407581810735@g.us",
+      chatType: "group",
+      body: "Brian what is your name",
+      senderE164: "+15550001111",
+    });
+
+    const route = applyWhatsAppRoutingPolicy({
+      cfg,
+      msg,
+      route: buildRoute(cfg, msg),
+      peerId: msg.from,
+    });
+
+    expect(route?.agentId).toBe("bsc");
+  });
+
+  it("blocks group messages when Brian is not mentioned", () => {
+    const cfg = makeConfig();
+    const msg = buildMessage({
+      from: "120363407581810735@g.us",
+      conversationId: "120363407581810735@g.us",
+      chatId: "120363407581810735@g.us",
+      chatType: "group",
+      body: "Michael what is your name",
+      senderE164: "+15550001111",
+    });
+
+    const route = applyWhatsAppRoutingPolicy({
+      cfg,
+      msg,
+      route: buildRoute(cfg, msg),
+      peerId: msg.from,
+    });
+
+    expect(route).toBeNull();
+  });
+});
diff --git a/extensions/whatsapp/src/auto-reply/monitor/routing-policy.ts b/extensions/whatsapp/src/auto-reply/monitor/routing-policy.ts
new file mode 100644
index 0000000000..63c09f95a2
--- /dev/null
+++ b/extensions/whatsapp/src/auto-reply/monitor/routing-policy.ts
@@ -0,0 +1,79 @@
+import type { loadConfig } from "openclaw/plugin-sdk/config-runtime";
+import type { resolveAgentRoute } from "openclaw/plugin-sdk/routing";
+import { normalizeE164 } from "openclaw/plugin-sdk/text-runtime";
+import {
+  buildMentionConfig,
+  isBotMentionedFromTargets,
+  resolveMentionTargets,
+} from "../mentions.js";
+import type { WebInboundMsg } from "../types.js";
+import { buildBroadcastRouteKeys } from "./broadcast.js";
+
+const OWNER_E164 = normalizeE164("+628176917122");
+const OWNER_DM_AGENT_IDS = ["main", "bsc", "zen"] as const;
+const GROUP_ONLY_AGENT_ID = "bsc";
+
+export function applyWhatsAppRoutingPolicy(params: {
+  cfg: ReturnType<typeof loadConfig>;
+  msg: WebInboundMsg;
+  route: ReturnType<typeof resolveAgentRoute>;
+  peerId: string;
+  authDir?: string;
+  logVerbose?: (message: string) => void;
+}) {
+  const mentionTargets = resolveMentionTargets(params.msg, params.authDir);
+  const wasMentionedForAgent = (agentId: string) =>
+    isBotMentionedFromTargets(params.msg, buildMentionConfig(params.cfg, agentId), mentionTargets);
+  const overrideRouteForAgent = (agentId: string) => {
+    const routeKeys = buildBroadcastRouteKeys({
+      cfg: params.cfg,
+      msg: params.msg,
+      route: params.route,
+      peerId: params.peerId,
+      agentId,
+    });
+    return {
+      ...params.route,
+      agentId,
+      ...routeKeys,
+    };
+  };
+
+  if (params.msg.chatType === "group") {
+    if (!wasMentionedForAgent(GROUP_ONLY_AGENT_ID)) {
+      params.logVerbose?.(
+        `Skipping WhatsApp group message without Brian mention in ${params.msg.conversationId ?? params.msg.from}`,
+      );
+      return null;
+    }
+    return params.route.agentId === GROUP_ONLY_AGENT_ID
+      ? params.route
+      : overrideRouteForAgent(GROUP_ONLY_AGENT_ID);
+  }
+
+  const senderE164 = normalizeE164(params.msg.senderE164 ?? params.msg.from ?? "");
+  const isOwnerDm = Boolean(senderE164 && OWNER_E164 && senderE164 === OWNER_E164);
+  let targetAgentId: string | null = null;
+
+  if (isOwnerDm) {
+    for (const agentId of OWNER_DM_AGENT_IDS) {
+      if (wasMentionedForAgent(agentId)) {
+        targetAgentId = agentId;
+        break;
+      }
+    }
+  } else if (wasMentionedForAgent("main")) {
+    targetAgentId = "main";
+  }
+
+  if (!targetAgentId) {
+    params.logVerbose?.(
+      `Skipping WhatsApp direct message without allowed named agent from ${senderE164 ?? params.msg.from}`,
+    );
+    return null;
+  }
+
+  return targetAgentId === params.route.agentId
+    ? params.route
+    : overrideRouteForAgent(targetAgentId);
+}
