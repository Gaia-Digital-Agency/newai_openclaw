@@ -0,0 +1,60 @@
+import { describe, expect, it } from "vitest";
+import type { OpenClawConfig } from "../config/config.js";
+import { createReplyPrefixContext } from "./reply-prefix.js";
+
+describe("createReplyPrefixContext whatsapp overrides", () => {
+  it("uses identity-based prefixes for WhatsApp replies", () => {
+    const cfg: OpenClawConfig = {
+      agents: {
+        list: [{ id: "main", identity: { name: "Michael" } }],
+      },
+    };
+
+    const result = createReplyPrefixContext({
+      cfg,
+      agentId: "main",
+      channel: "whatsapp",
+      accountId: "default",
+    });
+
+    expect(result.responsePrefix).toBe("Michael ♾️");
+  });
+
+  it("does not force the WhatsApp identity prefix on other channels", () => {
+    const cfg: OpenClawConfig = {
+      agents: {
+        list: [{ id: "main", identity: { name: "Michael" } }],
+      },
+    };
+
+    const result = createReplyPrefixContext({
+      cfg,
+      agentId: "main",
+      channel: "telegram",
+    });
+
+    expect(result.responsePrefix).toBeUndefined();
+  });
+
+  it("prefers the WhatsApp identity prefix over configured channel prefixes", () => {
+    const cfg: OpenClawConfig = {
+      agents: {
+        list: [{ id: "main", identity: { name: "Michael" } }],
+      },
+      channels: {
+        whatsapp: {
+          responsePrefix: "[WA] ",
+        },
+      },
+    };
+
+    const result = createReplyPrefixContext({
+      cfg,
+      agentId: "main",
+      channel: "whatsapp",
+      accountId: "default",
+    });
+
+    expect(result.responsePrefix).toBe("Michael ♾️");
+  });
+});
